NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_MAX_TOKENS=1024
NVIDIA_TEMPERATURE=0.1

# Embedding (local, no API key needed)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DEVICE=cpu

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db
COLLECTION_NAME=legal_docs

# Chunking
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# Retrieval
BM25_TOP_K=20
DENSE_TOP_K=20
RERANK_TOP_K=5
FINAL_CONTEXT_K=3
GRAPH_TOP_K=12
GRAPH_BOOST_WEIGHT=0.12

# OCR
MIN_NATIVE_CHARS_PER_PAGE=40
OCR_RENDER_DPI=220

# Entity graph
GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Hallucination thresholds
MIN_RELEVANCE_SCORE=0.30
MIN_ANSWER_COVERAGE=0.20
CONFIDENCE_SCALE_FACTOR=1.4

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
